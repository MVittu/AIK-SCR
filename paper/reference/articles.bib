  volume={49},
  pages={89-98},
  author={Stavrou V and Toubekis AG and Karetsi E},
  institution={Department of Physical Education and Sport Science, University of Thessaly, Trikala, Greece; Medical School, Department of Cardio-Pulmonary Testing, Pulmonary Clinic, University of Thessaly, Larissa, Greece.; Faculty of Physical Education and Sport Science, Department of Aquatic Sports, University of Athens, Athens, Greece.; Medical School, Department of Cardio-Pulmonary Testing, Pulmonary Clinic, University of Thessaly, Larissa, Greece.},
