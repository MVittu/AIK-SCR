    \entry{chiron_f_and_guloren_b_and_erblang_m_and_poirier_c_and_elbaz_m_and_servonnet_a_and_gaudin_m_and_le_coz_c_and_lopes_p_and_chennaoui_m_and_hanon_c_and_leger_d_and_thomas_c_exploring_2026}{article}{}{}
